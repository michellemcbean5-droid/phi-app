# ─── OpenAI Configuration ─────────────────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Model selection (gpt-4o recommended for production; gpt-4o-mini for lower cost testing)
OPENAI_MODEL=gpt-4o

# ─── Server Configuration ─────────────────────────────────────────────────────
PORT=8000
ENV=development   # Set to "production" to disable auto-reload

# ─── Database (optional — only needed if you use app/database.py) ─────────────
# DATABASE_URL=sqlite:///./phi.db
# DATABASE_URL=postgresql://user:password@localhost:5432/phi_db

# ─── Twilio SMS (Track & Trace Agent — broker/shipper tracking updates) ────────
# Free trial: https://www.twilio.com/try-twilio (includes $15 credit)
# The Track & Trace Liaison fires automated SMS updates on every load milestone.
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1...   # E.164 format, e.g. +15005550006

# ─── SendGrid Email (Finance Specialist — invoice & BOL to factoring) ──────────
# Free tier: 100 emails/day forever — https://signup.sendgrid.com
# The Finance Specialist emails the invoice + signed BOL to the factoring company.
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=invoices@yourcompany.com

# ─── Firebase Cloud Messaging (live driver push notifications) ─────────────────
# Create a Firebase project at https://console.firebase.google.com
# Go to Project Settings → Service Accounts → Generate New Private Key
# Then base64-encode the downloaded JSON: base64 -i service-account.json
# Fires for: load locked, HOS violation, breakdown/emergency alerts.
FIREBASE_SERVICE_ACCOUNT_B64=   # base64-encoded service-account JSON (recommended for cloud)
# FIREBASE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json  # local dev alternative
