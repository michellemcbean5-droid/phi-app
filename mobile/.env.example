# PHI Mobile App Environment Variables

# ===========================================
# REQUIRED VARIABLES
# ===========================================

# Expo Configuration
EXPO_PUBLIC_APP_ENV=development

# ===========================================
# API KEYS (Required for production)
# ===========================================

# DAT Load Board API
EXPO_PUBLIC_DAT_API_KEY=your_dat_api_key_here
EXPO_PUBLIC_DAT_API_BASE_URL=https://api.dat.com

# Google Maps API
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
EXPO_PUBLIC_GOOGLE_MAPS_BASE_URL=https://maps.googleapis.com

# Stripe Payment Processing
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
EXPO_PUBLIC_STRIPE_SECRET_KEY=your_stripe_secret_key_here
EXPO_PUBLIC_STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Twilio Communications
EXPO_PUBLIC_TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
EXPO_PUBLIC_TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
EXPO_PUBLIC_TWILIO_PHONE_NUMBER=+15551234567

# Samsara Telematics
EXPO_PUBLIC_SAMSARA_API_KEY=your_samsara_api_key_here
EXPO_PUBLIC_SAMSARA_API_BASE_URL=https://api.samsara.com

# ===========================================
# OPTIONAL VARIABLES
# ===========================================

# App Configuration
EXPO_PUBLIC_APP_NAME=Prince Haul Intelligence
EXPO_PUBLIC_APP_VERSION=1.0.0
EXPO_PUBLIC_APP_BUILD_NUMBER=1

# API Configuration
EXPO_PUBLIC_API_BASE_URL=https://api.yourdomain.com
EXPO_PUBLIC_API_TIMEOUT=30000
EXPO_PUBLIC_API_RETRY_ATTEMPTS=3

# Authentication
EXPO_PUBLIC_AUTH_BASE_URL=https://auth.yourdomain.com
EXPO_PUBLIC_AUTH_TOKEN_EXPIRY=86400000 # 24 hours in milliseconds

# Analytics
EXPO_PUBLIC_ANALYTICS_ENABLED=true
EXPO_PUBLIC_ANALYTICS_BASE_URL=https://analytics.yourdomain.com
EXPO_PUBLIC_MIXPANEL_TOKEN=your_mixpanel_token_here
EXPO_PUBLIC_AMPLITUDE_API_KEY=your_amplitude_api_key_here

# Error Tracking
EXPO_PUBLIC_SENTRY_DSN=your_sentry_dsn_here
EXPO_PUBLIC_SENTRY_ENABLED=true
EXPO_PUBLIC_SENTRY_ENVIRONMENT=development

# Feature Flags
EXPO_PUBLIC_FEATURE_AI_ENABLED=true
EXPO_PUBLIC_FEATURE_AUTO_BOOKING_ENABLED=true
EXPO_PUBLIC_FEATURE_REAL_TIME_TRACKING_ENABLED=true
EXPO_PUBLIC_FEATURE_ADVANCED_ANALYTICS_ENABLED=false

# ===========================================
# DEVELOPMENT VARIABLES
# ===========================================

# Development API Base URL
EXPO_PUBLIC_DEV_API_BASE_URL=http://localhost:3000

# Mock Data
EXPO_PUBLIC_USE_MOCK_DATA=true
EXPO_PUBLIC_MOCK_DATA_SEED=12345

# Debugging
EXPO_PUBLIC_DEBUG_ENABLED=true
EXPO_PUBLIC_DEBUG_LOG_LEVEL=debug # debug, info, warn, error

# ===========================================
# PRODUCTION VARIABLES
# ===========================================

# Production API Base URL
EXPO_PUBLIC_PROD_API_BASE_URL=https://api.princehaulintelligence.com

# Production Configuration
EXPO_PUBLIC_PROD_ENVIRONMENT=production
EXPO_PUBLIC_PROD_LOG_LEVEL=error # debug, info, warn, error

# ===========================================
# DATABASE CONFIGURATION
# ===========================================

# Firebase (if using Firebase)
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id_here
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
EXPO_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id_here
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id_here

# ===========================================
# PUSH NOTIFICATIONS
# ===========================================

# Firebase Cloud Messaging (FCM)
EXPO_PUBLIC_FCM_SERVER_KEY=your_fcm_server_key_here

# Apple Push Notification Service (APNS)
EXPO_PUBLIC_APNS_AUTH_KEY=your_apns_auth_key_here
EXPO_PUBLIC_APNS_TEAM_ID=your_apns_team_id_here
EXPO_PUBLIC_APNS_TOPIC=your_apns_topic_here

# ===========================================
# SOCIAL MEDIA
# ===========================================

# Facebook
EXPO_PUBLIC_FACEBOOK_APP_ID=your_facebook_app_id_here
EXPO_PUBLIC_FACEBOOK_CLIENT_TOKEN=your_facebook_client_token_here

# Google
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here
EXPO_PUBLIC_GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ===========================================
# PAYMENT PROCESSORS
# ===========================================

# PayPal
EXPO_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id_here
EXPO_PUBLIC_PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here

# Square
EXPO_PUBLIC_SQUARE_APPLICATION_ID=your_square_application_id_here
EXPO_PUBLIC_SQUARE_ACCESS_TOKEN=your_square_access_token_here
EXPO_PUBLIC_SQUARE_LOCATION_ID=your_square_location_id_here

# ===========================================
# STORAGE
# ===========================================

# AWS S3
EXPO_PUBLIC_AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
EXPO_PUBLIC_AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
EXPO_PUBLIC_AWS_REGION=us-east-1
EXPO_PUBLIC_AWS_S3_BUCKET=your_s3_bucket_name_here

# ===========================================
# EMAIL SERVICE
# ===========================================

# SendGrid
EXPO_PUBLIC_SENDGRID_API_KEY=your_sendgrid_api_key_here
EXPO_PUBLIC_SENDGRID_FROM_EMAIL=noreply@princehaulintelligence.com

# Mailgun
EXPO_PUBLIC_MAILGUN_API_KEY=your_mailgun_api_key_here
EXPO_PUBLIC_MAILGUN_DOMAIN=your_mailgun_domain_here

# ===========================================
# NOTES
# ===========================================

# 1. All variables prefixed with EXPO_PUBLIC_ are available to the client-side
# 2. Variables without the prefix are only available server-side
# 3. For production, use proper secret management (EAS secrets, etc.)
# 4. Never commit actual API keys or secrets to version control
# 5. Use .env.local for local development (not committed to git)
# 6. For production, use EAS secrets: eas secret:create --name API_KEY --value your_value

# Example of using secrets in EAS:
# eas secret:create --name EXPO_PUBLIC_DAT_API_KEY --value your_actual_key
# eas secret:push
