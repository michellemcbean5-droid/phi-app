# Use npm for package management
engine-strict=true

# Increase memory limit for builds
node-options=--max_old_space_size=4096

# Disable self-signed certificate checks in development
# strict-ssl=false

# Use the official npm registry
registry=https://registry.npmjs.org/

# Cache settings
cache=/tmp/npm-cache
cache-lock-stale=604800000
cache-lock-waits=10000
cache-max=0
