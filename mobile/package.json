    "@react-native-async-storage/async-storage": "1.23.1",
    "axios": "1.7.7",
    "expo": "54.0.0",
    "expo-asset": "11.0.4",
    "expo-font": "13.3.1",
    "expo-linear-gradient": "14.1.4",
    "expo-location": "18.1.5",
    "expo-notifications": "0.29.14",
    "expo-secure-store": "13.3.1",
    "expo-status-bar": "2.2.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
